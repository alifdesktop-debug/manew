{  "manifest_version": 3,  "name": "Crack By @Iamhear1",  "version": "1.0.0",  "description": "For free Bots and indicator join our telegram channel — click here: https://mrbeaxt.site/tg/index.html",  "icons": {    "16": "icons/mango-logo.png",    "48": "icons/mango-logo.png",    "128": "icons/mango-logo.png"  },  "background": {    "service_worker": "background.js"  },  "host_permissions": ["https://mrbeaxt.site/*"],  "action": {    "default_title": "Crack By @Iamhear1 — click the floating panel to run",    "default_icon": {      "16": "icons/mango-logo.png",      "48": "icons/mango-logo.png",      "128": "icons/mango-logo.png"    }  },  "content_scripts": [    {      "matches": ["<all_urls>"],      "js": ["content.js"],      "run_at": "document_idle",      "all_frames": false    }  ],  "web_accessible_resources": [    {      "resources": ["icons/mango-logo.png"],      "matches": ["<all_urls>"]    }  ]}